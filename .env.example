#--------------------
# OpenAI / LLM settings
#--------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

#--------------------
# Pipeline settings
#--------------------
TODAYINTECH_TIMEZONE=Asia/Seoul
TODAYINTECH_OUTPUT_DIR=docs
TODAYINTECH_RAW_OUTPUT_DIR=.var/local/raw
TODAYINTECH_PROCESSED_OUTPUT_DIR=.var/local/processed
TODAYINTECH_ENRICHED_OUTPUT_DIR=.var/local/enriched
TODAYINTECH_ENRICHMENT_CACHE_DIR=.var/local/enrichment-cache
TODAYINTECH_TRACE_OUTPUT_DIR=.var/local/traces
TODAYINTECH_BRIEFED_ARTICLES_PATH=data/briefed_articles.json
TODAYINTECH_WRITER_AGENT=draft
TODAYINTECH_MAX_ARTICLES_PER_SERVICE=5
TODAYINTECH_MAX_CANDIDATES_PER_SERVICE=10
TODAYINTECH_MAX_CANDIDATES_TOTAL=50
TODAYINTECH_ENRICHMENT_TIMEOUT_SECONDS=20
TODAYINTECH_ENRICHMENT_MAX_ATTEMPTS=2
TODAYINTECH_ENRICHMENT_MINIMUM_TOKENS=100
TODAYINTECH_ENRICHMENT_FULL_CONTENT_MAX_TOKENS=4000
TODAYINTECH_ENRICHMENT_CHUNK_SELECTION_MAX_TOKENS=8000
TODAYINTECH_ENRICHMENT_CHUNK_MAX_TOKENS=1200
TODAYINTECH_ENRICHMENT_SELECTED_CHUNKS_MAX_TOKENS=4000

#--------------------
# Local reproducibility settings
#--------------------
TODAYINTECH_TARGET_DATE=

#--------------------
# Docusaurus / GitHub Pages settings
#--------------------
DOCUSAURUS_URL=https://example.com
DOCUSAURUS_BASE_URL=/
