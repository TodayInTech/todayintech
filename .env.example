# Today in Tech environment variables

# Required when LLM-based scoring/summarization is enabled.
OPENAI_API_KEY=

# Optional LLM settings. Current scaffold keeps these as reserved settings.
OPENAI_MODEL=gpt-5-mini

# Pipeline settings.
TODAYINTECH_TIMEZONE=Asia/Seoul
TODAYINTECH_OUTPUT_DIR=docs
TODAYINTECH_RAW_OUTPUT_DIR=data/raw
TODAYINTECH_MAX_ARTICLES_PER_SERVICE=5

# Optional override for reproducible local generation.
# Format: YYYY-MM-DD
TODAYINTECH_TARGET_DATE=

# Docusaurus / GitHub Pages settings.
# Set these when deploying under a real GitHub Pages URL.
DOCUSAURUS_URL=https://example.com
DOCUSAURUS_BASE_URL=/
