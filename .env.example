#--------------------
# OpenAI / LLM settings
#--------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

#--------------------
# Pipeline settings
#--------------------
TODAYINTECH_TIMEZONE=Asia/Seoul
TODAYINTECH_OUTPUT_DIR=docs
TODAYINTECH_RAW_OUTPUT_DIR=.var/local/raw
TODAYINTECH_PROCESSED_OUTPUT_DIR=.var/local/processed
TODAYINTECH_TRACE_OUTPUT_DIR=.var/local/traces
TODAYINTECH_BRIEFED_ARTICLES_PATH=data/briefed_articles.json
TODAYINTECH_MAX_ARTICLES_PER_SERVICE=5
TODAYINTECH_MAX_CANDIDATES_PER_SERVICE=10
TODAYINTECH_MAX_CANDIDATES_TOTAL=50

#--------------------
# Local reproducibility settings
#--------------------
TODAYINTECH_TARGET_DATE=

#--------------------
# Docusaurus / GitHub Pages settings
#--------------------
DOCUSAURUS_URL=https://example.com
DOCUSAURUS_BASE_URL=/
